{
  "version": 2,
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/api/$1"
    },
    {
      "src": "/",
      "dest": "/public_html/index.html"
    },
    {
      "src": "/test",
      "dest": "/public_html/index.html"
    }
  ]
}
